# Firebase Web SDK config — copy from Firebase Console (Project settings → Your apps → Web).
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Backend API base URL.
EXPO_PUBLIC_API_URL=http://localhost:3000

# Logo.dev publishable token for brand logos (https://logo.dev). Optional —
# without it BrandIcon falls back to DuckDuckGo favicons.
EXPO_PUBLIC_LOGO_DEV_TOKEN=
