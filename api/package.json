{
  "name": "@unsub/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "kill-port 3000 && tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/db/migrate.js && node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "rollover": "tsx src/jobs/rollover.ts",
    "backfill:recent-events": "tsx src/jobs/backfill-recent-events.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/sensible": "^6.0.3",
    "@unsub/shared": "workspace:*",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.44.5",
    "fastify": "^5.6.1",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^5.0.0",
    "firebase-admin": "^13.5.0",
    "pg": "^8.13.1",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.7.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.5",
    "kill-port": "^2.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
