# Backend environment — copy to api/.env and fill in.

NODE_ENV=development
PORT=3000

# Postgres (Neon connection string).
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Firebase Admin SDK (service-account JSON, broken into three vars).
# Paste FIREBASE_PRIVATE_KEY with literal \n escape sequences — env.ts will unescape.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Google OAuth (Gmail readonly). Web-application credentials.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:3000/auth/google/callback

# 32-byte hex key for AES-256-GCM encryption of refresh tokens at rest +
# HMAC of OAuth state. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Shared secret for /admin/rollover (the daily renewal-rollover endpoint
# hit by GitHub Actions cron). At least 16 chars. When unset the endpoint
# returns 503, so it's safe to leave blank in environments without a cron.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ROLLOVER_TOKEN=

# Optional — set by host (Render injects RENDER_GIT_COMMIT), falls back to "dev".
GIT_SHA=
